{
  "name": "yaguri-tools",
  "version": "3.6.3",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "dev:mcp": "tsx --env-file=.env src/mcp-entry.ts",
    "build": "tsup src/index.ts src/mcp-entry.ts --format cjs --out-dir dist --clean",
    "start": "node --env-file=.env dist/index.js",
    "start:mcp": "node --env-file=.env dist/mcp-entry.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
